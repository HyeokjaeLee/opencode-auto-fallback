  "description": "OpenCode plugin that automatically switches to a fallback model when rate limits are hit",
  "type": "module",
  "main": "index.ts",
  "author": "HyeokjaeLee",
  "files": [
    "index.ts",
    "src",
    "docs"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
