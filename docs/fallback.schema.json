{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/HyeokjaeLee/opencode-auto-fallback/main/docs/fallback.schema.json",
  "title": "OpenCode Auto Fallback Configuration",
  "description": "Configuration for automatic model fallback on rate limits and errors",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Enable or disable the auto-fallback plugin",
      "default": true
    },
    "defaultFallback": {
      "description": "Default fallback model chain. When omitted, only agents explicitly listed in agentFallbacks will trigger fallback.",
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "#/$defs/fallbackEntry" },
          "minItems": 1
        },
        {
          "type": "string",
          "description": "Single fallback model (e.g. 'openai/gpt-5.4')"
        }
      ],
      "default": []
    },
    "agentFallbacks": {
      "type": "object",
      "description": "Per-agent fallback model chains. Key is agent name, value is fallback chain.",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "array",
            "items": { "$ref": "#/$defs/fallbackEntry" }
          },
          {
            "type": "string",
            "description": "Single fallback model for this agent"
          }
        ]
      },
      "default": {}
    },
    "cooldownMs": {
      "type": "number",
      "description": "Cooldown duration in milliseconds after immediate fallback (prevents rapid fallback loops)",
      "default": 60000,
      "minimum": 0
    },
    "maxRetries": {
      "type": "number",
      "description": "Maximum retry attempts with exponential backoff before switching to fallback chain",
      "default": 2,
      "minimum": 0
    },
    "logging": {
      "type": "boolean",
      "description": "Enable file-based logging to ~/.local/share/opencode/log/fallback.log",
      "default": false
    },
    "largeContextFallback": {
      "type": "object",
      "description": "Automatically switch to a larger model when an agent's context window fills up. Switches back to the original model after compaction.",
      "properties": {
        "agents": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of agent names to apply large context fallback to",
          "minItems": 1
        },
        "model": {
          "type": "string",
          "description": "Model to switch to when context fills up (e.g. 'openai/gpt-5.5')"
        }
      },
      "required": ["agents", "model"],
      "additionalProperties": false
    }
  },
  "$defs": {
    "fallbackEntry": {
      "oneOf": [
        {
          "type": "string",
          "description": "Simple fallback model (e.g. 'openai/gpt-5.4' or 'provider/model')"
        },
        {
          "type": "object",
          "description": "Fallback model with optional parameters",
          "required": ["model"],
          "properties": {
            "model": {
              "type": "string",
              "description": "Model reference (e.g. 'openai/gpt-5.4', 'anthropic/claude-sonnet-4')"
            },
            "variant": {
              "type": "string",
              "description": "Model variant (e.g. 'high', 'medium', 'low')"
            },
            "reasoningEffort": {
              "type": "string",
              "enum": ["none", "minimal", "low", "medium", "high", "xhigh"],
              "description": "Reasoning effort level"
            },
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2,
              "description": "Temperature for generation"
            },
            "topP": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Top-p sampling"
            },
            "maxTokens": {
              "type": "number",
              "minimum": 1,
              "description": "Maximum output tokens"
            },
            "thinking": {
              "type": "object",
              "description": "Thinking mode configuration",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["enabled", "disabled"]
                },
                "budgetTokens": {
                  "type": "number",
                  "minimum": 1,
                  "description": "Token budget for thinking"
                }
              }
            }
          }
        }
      ]
    }
  }
}
